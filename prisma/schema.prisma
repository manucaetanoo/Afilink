// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// prisma/schema.prisma
datasource db {
  provider  = "postgresql"

}

model User {
  id           String   @id @default(cuid())
  email        String   @unique

  // 👤 Perfil
  name         String?  @db.VarChar(60)   // nombre
  lastName     String?  @db.VarChar(60)   // apellido
  username     String?  @unique @db.VarChar(30)
  image        String?                 // URL avatar
  timezone     String?  @db.VarChar(64)

  // 🔐 Auth / sistema
  passwordHash String?
  role         Role     @default(AFFILIATE)
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 🔗 Relaciones
  products     Product[]
  links        AffiliateLink[]
  commissions  Commission[]

  @@index([role])
  @@index([isActive])
  @@index([username])
}



model Product {
  id        String   @id @default(cuid())
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id])


  name      String
  desc      String? // el ? hace que sea opcional
  price     Int
  imageUrls String[] // ✅ varias fotos

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissionValue Int @default(5)
  commissionType CommissionType @default(PERCENT)

  links     AffiliateLink[]
  orders    Order[]
}



model AffiliateLink {
  id          String   @id @default(cuid())
  code        String   @unique
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  affiliateId String
  affiliate   User     @relation(fields: [affiliateId], references: [id])
  createdAt   DateTime @default(now())

  clicks      Click[]

   @@unique([productId, affiliateId])
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  link      AffiliateLink @relation(fields: [linkId], references: [id])
  createdAt DateTime @default(now())

  //para las analytics
  ip        String?
  userAgent String?
  orders   Order[]
}

model Order {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  total     Int
  createdAt DateTime @default(now())
  status   OrderStatus @default(PENDING)
    
  clickId   String?
  click     Click?   @relation(fields: [clickId], references: [id])

  commission Commission?
}

model Commission {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  affiliateId String
  affiliate   User     @relation(fields: [affiliateId], references: [id])
  amount      Int
  status      CommissionStatus @default(PENDING)
  createdAt   DateTime @default(now())
}

enum Role {
  SELLER
  AFFILIATE
  ADMIN
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}

enum CommissionType {
  PERCENT
  FIXED
}
