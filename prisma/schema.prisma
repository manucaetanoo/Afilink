generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(cuid())
  email String @unique @db.VarChar(191)

  // Perfil
  name     String? @db.VarChar(60)
  image    String?
  timezone String? @db.VarChar(64)

  notifications Notification[]

  // Store
  storeSlug String? @unique @db.VarChar(80)

  // Datos de cobro / liquidacion
  payoutMethod         PayoutMethod? @default(BANK_TRANSFER)
  payoutHolderName     String?       @db.VarChar(120)
  payoutDocumentType   String?       @db.VarChar(30)
  payoutDocumentNumber String?       @db.VarChar(40)
  payoutEmail          String?       @db.VarChar(191)
  payoutPhone          String?       @db.VarChar(40)
  payoutCountry        String?       @db.VarChar(2)
  payoutCurrency       String?       @db.VarChar(10)
  bankName             String?       @db.VarChar(120)
  bankAccountType      String?       @db.VarChar(30)
  bankAccountNumber    String?       @db.VarChar(80)
  bankAccountAlias     String?       @db.VarChar(120)
  bankBranch           String?       @db.VarChar(120)
  payoutNotes          String?       @db.Text

  // Auth / sistema
  passwordHash String?
  role         Role    @default(AFFILIATE)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  products            Product[]               @relation("SellerProducts")
  campaigns           Campaign[]              @relation("SellerCampaigns")
  links               AffiliateLink[]         @relation("AffiliateLinks")
  campaignLinks       AffiliateCampaignLink[] @relation("AffiliateCampaignLinks")
  commissions         Commission[]            @relation("AffiliateCommissions")
  affiliateOrders     Order[]                 @relation("OrderAffiliate")
  affiliateItems      OrderItem[]             @relation("OrderItemAffiliate")
  sellerOrders        Order[]                 @relation("OrderSeller")
  sellerItems         OrderItem[]             @relation("OrderItemSeller")
  settlements         Settlement[]            @relation("SellerSettlements")
  payoutRequests      PayoutRequest[]
  passwordResetTokens PasswordResetToken[]

  @@index([role])
  @@index([isActive])
  @@index([storeSlug])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @db.VarChar(191)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String    @db.VarChar(50)
  title     String    @db.VarChar(140)
  message   String    @db.Text
  readAt    DateTime?
  orderId   String?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Product {
  id String @id @default(cuid())

  sellerId String
  seller   User   @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)

  name      String          @db.VarChar(140)
  desc      String?         @db.Text
  price     Int
  stock     Int             @default(0)
  category  ProductCategory @default(OTHER)
  sizes     String[]        @default([])
  imageUrls String[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Comisión del afiliado (la define el seller)
  commissionValue Int            @default(10)
  commissionType  CommissionType @default(PERCENT)

  // Comisión de la plataforma
  platformCommissionValue Int            @default(5)
  platformCommissionType  CommissionType @default(PERCENT)

  links            AffiliateLink[]
  orders           Order[]
  orderItems       OrderItem[]
  campaignProducts CampaignProduct[]

  @@index([sellerId])
  @@index([isActive])
  @@index([stock])
  @@index([sellerId, isActive])
}

model Campaign {
  id          String  @id @default(cuid())
  title       String  @db.VarChar(120)
  slug        String  @db.VarChar(140)
  description String? @db.Text
  bannerUrl   String?
  isActive    Boolean @default(true)

  // Opcional: fechas de vigencia
  startsAt DateTime?
  endsAt   DateTime?

  // Relación con seller
  sellerId String
  seller   User   @relation("SellerCampaigns", fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products       CampaignProduct[]
  affiliateLinks AffiliateCampaignLink[]
  orders         Order[]
  orderItems     OrderItem[]

  @@unique([sellerId, slug])
  @@index([sellerId])
  @@index([sellerId, isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model CampaignProduct {
  id String @id @default(cuid())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([campaignId, productId])
  @@index([campaignId])
  @@index([productId])
}

model AffiliateLink {
  id   String @id @default(cuid())
  code String @unique @db.VarChar(120)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  affiliateId String
  affiliate   User   @relation("AffiliateLinks", fields: [affiliateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  clicks Click[]

  @@unique([productId, affiliateId])
  @@index([affiliateId])
  @@index([productId])
}

model AffiliateCampaignLink {
  id   String @id @default(cuid())
  code String @unique @db.VarChar(120)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  affiliateId String
  affiliate   User   @relation("AffiliateCampaignLinks", fields: [affiliateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  clicks CampaignClick[]

  @@unique([campaignId, affiliateId])
  @@index([affiliateId])
  @@index([campaignId])
}

model Click {
  id String @id @default(cuid())

  linkId String
  link   AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Analytics
  ip        String? @db.VarChar(64)
  userAgent String? @db.Text

  orders     Order[]
  orderItems OrderItem[]

  @@index([linkId])
  @@index([createdAt])
}

model CampaignClick {
  id String @id @default(cuid())

  linkId String
  link   AffiliateCampaignLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Analytics
  ip        String? @db.VarChar(64)
  userAgent String? @db.Text

  orders     Order[]
  orderItems OrderItem[]

  @@index([linkId])
  @@index([createdAt])
}

model Order {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  sellerId String
  seller   User   @relation("OrderSeller", fields: [sellerId], references: [id], onDelete: Restrict)

  affiliateId String?
  affiliate   User?   @relation("OrderAffiliate", fields: [affiliateId], references: [id], onDelete: SetNull)

  // opcional: si la venta vino desde una campaña
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  total     Int
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // atribución por link de producto
  clickId String?
  click   Click?  @relation(fields: [clickId], references: [id], onDelete: SetNull)

  // atribución por link de campaña
  campaignClickId String?
  campaignClick   CampaignClick? @relation(fields: [campaignClickId], references: [id], onDelete: SetNull)

  // Snapshot de comisión afiliado al momento de la compra
  commissionValue Int
  commissionType  CommissionType
  affiliateAmount Int            @default(0)

  // Snapshot de comisión plataforma al momento de la compra
  platformCommissionValue Int
  platformCommissionType  CommissionType
  platformAmount          Int            @default(0)

  // Lo que le queda al seller
  sellerAmount Int @default(0)

  // Datos del pago
  paymentProvider String? @db.VarChar(50)
  paymentId       String? @db.VarChar(191)
  paymentStatus   String? @db.VarChar(50)

  // Datos de contacto y entrega
  buyerName          String? @db.VarChar(140)
  buyerEmail         String? @db.VarChar(191)
  buyerPhone         String? @db.VarChar(40)
  shippingStreet     String? @db.VarChar(160)
  shippingNumber     String? @db.VarChar(30)
  shippingApartment  String? @db.VarChar(60)
  shippingCity       String? @db.VarChar(120)
  shippingState      String? @db.VarChar(120)
  shippingPostalCode String? @db.VarChar(20)
  shippingCountry    String? @db.VarChar(2)
  shippingNotes      String? @db.Text

  commissions Commission[]
  settlements Settlement[]
  items       OrderItem[]

  @@index([productId])
  @@index([sellerId])
  @@index([affiliateId])
  @@index([campaignId])
  @@index([status])
  @@index([clickId])
  @@index([campaignClickId])
  @@index([createdAt])
  @@index([sellerId, status])
  @@index([affiliateId, status])
}

model Commission {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderItemId String?    @unique
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  affiliateId String
  affiliate   User   @relation("AffiliateCommissions", fields: [affiliateId], references: [id], onDelete: Cascade)

  amount    Int
  status    CommissionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([affiliateId])
  @@index([status])
  @@index([affiliateId, status])
  @@index([orderId])
}

model Settlement {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  sellerId String
  seller   User   @relation("SellerSettlements", fields: [sellerId], references: [id], onDelete: Cascade)

  // Monto total cobrado al comprador
  grossAmount Int

  // Comisión que retiene la plataforma
  platformFee Int

  // Comisión que corresponde al afiliado (si hubo)
  affiliateFee Int

  // Monto que le corresponde al seller
  netAmount Int

  // Logistica gestionada por el seller
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  shippingCarrier   String?           @db.VarChar(80)
  trackingCode      String?           @db.VarChar(120)
  trackingUrl       String?           @db.VarChar(300)
  shippedAt         DateTime?
  deliveredAt       DateTime?
  sellerNotes       String?           @db.Text

  status    SettlementStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([orderId, sellerId])
  @@index([sellerId])
  @@index([status])
  @@index([fulfillmentStatus])
  @@index([sellerId, status])
  @@index([orderId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  sellerId String
  seller   User   @relation("OrderItemSeller", fields: [sellerId], references: [id], onDelete: Restrict)

  affiliateId String?
  affiliate   User?   @relation("OrderItemAffiliate", fields: [affiliateId], references: [id], onDelete: SetNull)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  // atribucion por link de producto
  clickId String?
  click   Click?  @relation(fields: [clickId], references: [id], onDelete: SetNull)

  // atribucion por link de campaña
  campaignClickId String?
  campaignClick   CampaignClick? @relation(fields: [campaignClickId], references: [id], onDelete: SetNull)

  quantity     Int     @default(1)
  selectedSize String? @db.VarChar(30)
  unitPrice    Int
  total        Int

  // Snapshot de comision afiliado al momento de la compra
  commissionValue Int
  commissionType  CommissionType
  affiliateAmount Int            @default(0)

  // Snapshot de comision plataforma al momento de la compra
  platformCommissionValue Int
  platformCommissionType  CommissionType
  platformAmount          Int            @default(0)

  // Lo que le queda al seller
  sellerAmount Int @default(0)

  commission Commission?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([sellerId])
  @@index([affiliateId])
  @@index([campaignId])
  @@index([clickId])
  @@index([campaignClickId])
  @@index([sellerId, createdAt])
  @@index([affiliateId, createdAt])
}

model PayoutRequest {
  id String @id @default(cuid())

  requesterId String
  requester   User   @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  kind   PayoutRequestKind
  amount Int
  status PayoutRequestStatus @default(PENDING)

  requestedAt DateTime  @default(now())
  paidAt      DateTime?
  adminNotes  String?   @db.Text

  @@index([requesterId])
  @@index([kind])
  @@index([status])
  @@index([requestedAt])
}

enum Role {
  SELLER
  AFFILIATE
  ADMIN
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}

enum CommissionType {
  PERCENT
  FIXED
}

enum ProductCategory {
  CLOTHING
  SHOES
  ACCESSORIES
  BEAUTY
  HOME
  DIGITAL
  OTHER
}

enum SettlementStatus {
  PENDING
  AVAILABLE
  PAID
  CANCELED
}

enum FulfillmentStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  CANCELED
}

enum PayoutMethod {
  BANK_TRANSFER
  DLOCAL_GO
  MANUAL
}

enum PayoutRequestKind {
  SELLER
  AFFILIATE
}

enum PayoutRequestStatus {
  PENDING
  PAID
  CANCELED
}
